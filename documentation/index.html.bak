									<section id="upgrade_guide">
										<h3>Upgrade Guide</h3>
										<strong>Follow the steps below to upgrade TechGuru system </strong>
										<ul class="code">
											<li>
												<div class="steps-panel">
													<ol class="ordered-list">
														<li>Login the admin panel</li>
														<li>Go to the Managements</li>
														<li>Click on the Upgrade button</li>
														<li>You can update CMS, Plugins, and Themes</li>
													</ol>
												</div>
												<figure>
													<img class="max-100" src="assets/images/demo/update/1.png" alt="">
