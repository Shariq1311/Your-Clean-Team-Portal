{
    "name": "mojar/cms",
    "type": "project",
    "description": "Mojar CMS is a Content Management System (CMS) developed based on Laravel Framework and web platform whose sole purpose is to make your development workflow simple again. Project develop by Mojar",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-simplexml": "*",
        "ext-zip": "*",
        "arcanedev/log-viewer": "^10.0",
        "composer/installers": "^2.2",
        "darkaonline/l5-swagger": "^8.3",
        "doctrine/dbal": "^3.3",
        "erag/laravel-pwa": "^1.9",
        "google/apiclient": "^2.13",
        "guzzlehttp/guzzle": "^7.2",
        "hassankhan/config": "^3.2",
        "inertiajs/inertia-laravel": "^1.0",
        "intervention/image": "^2.7",
        "kirschbaum-development/eloquent-power-joins": "^3.2",
        "laravel/breeze": "^1.21",
        "laravel/framework": "^10.0",
        "laravel/passport": "^11.8",
        "laravel/socialite": "^5.5",
        "laravel/tinker": "^2.8",
        "league/fractal": "^0.20.1",
        "oomphinc/composer-installers-extender": "^2.0",
        "pion/laravel-chunk-upload": "^1.5",
        "razorpay/razorpay": "^2.9",
        "rcrowe/twigbridge": "^0.14.5",
        "sentry/sentry-laravel": "^4.15",
        "spatie/image-optimizer": "^1.4",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-feed": "^4.4",
        "spatie/laravel-translation-loader": "^2.8"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "barryvdh/laravel-ide-helper": "^2.15",
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "laravel/telescope": "^4.17",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.10",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "MojarCMS\\": "modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "modules/CMS/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan mojarcms:plugin-autoload"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan mojarcms:plugin-autoload"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan mojarcms:plugin-autoload"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "installer-types": [
            "mojar-plugin",
            "mojar-theme"
        ],
        "installer-paths": {
            "plugins/{$name}/": [
                "type:mojar-plugin"
            ],
            "themes/{$name}/": [
                "type:mojar-theme"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "composer/installers": true,
            "oomphinc/composer-installers-extender": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
