namespace MojarCMS\CMS\Providers;

use Illuminate\Console\Scheduling\Schedule;
use MojarCMS\Backend\Commands\AutoSubmitCommand;
use MojarCMS\Backend\Commands\AutoTagCommand;
use MojarCMS\CMS\Console\Commands\AutoClearSlotCommand;
use MojarCMS\CMS\Console\Commands\ClearCacheCommand;
use MojarCMS\CMS\Console\Commands\ClearCacheExpiredCommand;
use MojarCMS\CMS\Console\Commands\InstallCommand;
use MojarCMS\CMS\Console\Commands\PluginAutoloadCommand;
use MojarCMS\CMS\Console\Commands\SendMailCommand;
use MojarCMS\CMS\Console\Commands\ShowSlotCommand;
use MojarCMS\CMS\Console\Commands\UpdateCommand;
use MojarCMS\CMS\Console\Commands\VersionCommand;
use MojarCMS\CMS\Support\ServiceProvider;

class ConsoleServiceProvider extends ServiceProvider
{
    protected array $commands = [
        InstallCommand::class,
        UpdateCommand::class,
        SendMailCommand::class,
        ClearCacheCommand::class,
        PluginAutoloadCommand::class,
        AutoClearSlotCommand::class,
        ShowSlotCommand::class,
        ClearCacheExpiredCommand::class,
        VersionCommand::class
    ];

    public function boot(): void
    {
        $this->app->booted(
            function () {
                $schedule = $this->app->make(Schedule::class);
                $schedule->command(AutoClearSlotCommand::class)->hourly();
                $schedule->command(AutoSubmitCommand::class)->daily();

                if (get_config('mc_auto_add_tags_to_posts')) {
                    $schedule->command(AutoTagCommand::class)->dailyAt('03:16');
                }

                if (get_config('mc_backup_enable')) {
                    $schedule->command('backup:clean')->daily();
                    $time = get_config('mc_backup_time', 'daily');
                    switch ($time) {
                        case 'weekly':
                            $schedule->command('backup:run')->weekly();
                            break;
                        case 'monthly':
                            $schedule->command('backup:run')->monthly();
                            break;
                        default:
                            $schedule->command('backup:run')->daily();
                    }
                }
            }
        );
    }

    public function register(): void
    {
        $this->commands($this->commands);
    }

    /**
     * @return array
     */
    public function provides(): array
    {
        return $this->commands;
    }
}
