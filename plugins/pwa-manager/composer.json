{
    "name": "mojahid/pwa-manager",
    "description": "Progressive Web App (PWA) Manager plugin for Your Clean Team CMS - Complete PWA functionality with admin configuration, manifest generation, and service worker management",
    "type": "Your Clean Team-plugin",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Mojahid Hassan",
            "email": "contact@mojahid.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^9.0|^10.0|^11.0",
        "erag/laravel-pwa": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Mojahid\\PwaManager\\": "src/"
        }
    },
    "extra": {
        "Your Clean Team": {
            "name": "PWA Manager",
            "domain": "pwa",
            "cms_min": "1.0.0",
            "version": "1.0.0",
            "providers": [
                "Mojahid\\PwaManager\\Providers\\PwaServiceProvider"
            ]
        }
    },
    "keywords": [
        "laravel",
        "pwa",
        "progressive web app",
        "cms",
        "Your Clean Team",
        "service worker",
        "manifest"
    ],
    "homepage": "https://github.com/mojahid/pwa-manager",
    "support": {
        "issues": "https://github.com/mojahid/pwa-manager/issues",
        "source": "https://github.com/mojahid/pwa-manager"
    },
    "minimum-stability": "stable"
} 