{
    "name": "mojahid/pos-system",
    "description": "Point of Sale System for MojarCMS",
    "type": "mojar-plugin",
    "license": "GPL-3.0-or-later",
    "version": "1.0.0",
    "homepage": "https://mojar.com",
    "authors": [
        {
            "name": "Mojar Team",
            "email": "info@mojar.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "mojahid/cms": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Mojahid\\PosSystem\\": "src/"
        },
        "files": [
            "helpers/helpers.php"
        ]
    },
    "extra": {
        "mojar": {
            "name": "POS System",
            "domain": "pos",
            "cms_min": "1.0.0",
            "version": "1.0.0",
            "providers": [
                "Mojahid\\PosSystem\\Providers\\PosSystemServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
} 