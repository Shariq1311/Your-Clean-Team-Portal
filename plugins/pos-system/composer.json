{
    "name": "mojahid/pos-system",
    "description": "Point of Sale System for Your Clean TeamCMS",
    "type": "Your Clean Team-plugin",
    "license": "GPL-3.0-or-later",
    "version": "1.0.0",
    "homepage": "https://Your Clean Team.com",
    "authors": [
        {
            "name": "Your Clean Team Team",
            "email": "info@Your Clean Team.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "mojahid/cms": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Mojahid\\PosSystem\\": "src/"
        },
        "files": [
            "helpers/helpers.php"
        ]
    },
    "extra": {
        "Your Clean Team": {
            "name": "POS System",
            "domain": "pos",
            "cms_min": "1.0.0",
            "version": "1.0.0",
            "providers": [
                "Mojahid\\PosSystem\\Providers\\PosSystemServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
} 