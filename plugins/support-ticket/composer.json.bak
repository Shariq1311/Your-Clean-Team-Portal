{
    "name": "mojahid/support-ticket",
    "homepage": "https://mojahid.com",
    "type": "mojar-plugin",
    "license": "MIT",
    "description": "Open and management support tickets for your websites",
    "extra": {
        "mojar": {
            "name": "Support Ticket",
            "domain": "sticket",
            "cms_min": "1.0.0",
            "version": "1.0.0",
            "providers": [
                "Mojahid\\SupportTicket\\Providers\\SupportTicketServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Mojahid\\SupportTicket\\": "src/"
        }
    },
    "require-dev": {
        "mojarcms/modules": "^1.0",
        "mojarcms/dev-tool": "^1.0"
    }
}
