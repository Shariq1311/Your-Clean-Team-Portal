{% extends 'cms::layouts.frontend' %}

{% block content %}

{% include 'theme::components.breadcrumb' with {
        title: '404',
		description: 'The page you are looking for does not exist. It might have been moved or deleted.',
        items: [
            {'label': 'Home', 'url': '/'},
            {'label': '404'}
        ]
    } %}
  <section class="error-page">
    <div class="container">
        <div class="error-page__inner text-center">
            <div class="error-page__img float-bob-y">
                <img src="{{ asset('images/resources/error-page-img1.png') }}" alt="404">  
            </div>

            <div class="error-page__content">
                <h2>{{ __('Oops! Page Not Found!') }}</h2>  
                <p>{{ __('The page you are looking for does not exist. It might have been moved or deleted.') }}</p>
                <div class="btn-box">
                    <a class="thm-btn" href="{{ home_url() }}">
                    {{ __('Back To Home') }}
                      <span class="icon-right-arrow"></span></a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}

