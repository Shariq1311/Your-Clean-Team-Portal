<script>
    $(document).ready(function() {
        // Tab functionality
        $('.tab-btn').on('click', function() {
            var target = $(this).data('tab');
            
            // Remove active classes
            $('.tab-btn').removeClass('active-btn');
            $('.tab').removeClass('active-tab');
            
            // Add active classes
            $(this).addClass('active-btn');
            $(target).addClass('active-tab');
        });
    });
</script> 