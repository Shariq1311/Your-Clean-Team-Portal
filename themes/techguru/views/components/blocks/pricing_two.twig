                </li>
                <li data-tab="#yearly" class="tab-btn {% if data.default_active_tab == 'yearly' or not data.default_active_tab %}active-btn{% endif %}"><span>{{ data.tab_2_title|default('Yearly') }}</span></li>
                <li data-tab="#packges" class="tab-btn {% if data.default_active_tab == 'packges' %}active-btn{% endif %}"><span>{{ data.tab_3_title|default('Packages') }}</span></li>
            </ul>
