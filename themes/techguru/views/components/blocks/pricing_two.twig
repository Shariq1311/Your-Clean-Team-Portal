                                'limit': data.monthly_items_limit|default(3),
                                'taxonomy': data.monthly_category,
                                'ids': monthly_ids_array,
                                'orderby': 'date',
                                'order': 'DESC'
                            }) %}
                            
                            {% if monthly_pricing_plans %}
                                {% for index, plan in monthly_pricing_plans %}
                                    <!--Pricing Two Single Start-->
                                    <div class="col-xl-4 col-lg-6">
                                        <div class="pricing-two__single pricing-two__single-{{ (index % 3) + 1 }}">
                                            {% if (index % 3) == 1 %}
                                                <div class="pricing-two__single-shape-2">
                                                    <img src="{{ asset('images/shapes/pricing-two-single-shape-2.png') }}" alt="">
                                                </div>
                                            {% else %}
                                                <div class="pricing-two__single-shape-1">
                                                    <img src="{{ asset('images/shapes/pricing-two-single-shape-1.png') }}" alt="">
                                                </div>
