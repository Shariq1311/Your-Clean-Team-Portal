                                            </div>
                                            <div class="pricing-two__shape-2">
                                                <img src="{{ asset('images/shapes/pricing-two-shape-2.png') }}" alt="">
                                            </div>
                                            <div class="pricing-two__shape-3">
                                                <img src="{{ asset('images/shapes/pricing-two-shape-3.png') }}" alt="">
                                            </div>
                                            <span class="pricing-two__sub-title">{{ plan.title }}</span>
                                            <h2 class="pricing-two__price">{{ plan.metas.price|default('$0.00') }}</h2>
                                            <p class="pricing-two__text">{{ plan.description|default('Contact for pricing')|raw }}
                                            </p>
                                            <div class="pricing-two__btn-box">
                                                <a href="{{ plan.metas.price_button_url|default('#') }}" class="pricing-two__btn">{{ plan.metas.price_button_text|default('Choose Plan') }}<span class="far fa-plus-circle"></span></a>
                                            </div>
                                            <h5 class="pricing-two__points-title">{{ data.features_title|default('Feature Description') }}</h5>
                                            <ul class="pricing-two__points list-unstyled">
                                                {% if plan.metas.features_list %}
                                                    {% for feature in plan.metas.features_list %}
                                                        <li>
                                                            <div class="icon">
                                                                {% if feature.features_active %}
                                                                    <span class="icon-tick-inside-circle"></span>
                                                                {% else %}
                                                                    <span class="far fa-plus-circle"></span>
                                                                {% endif %}
                                                            </div>
                                                            <p>{{ feature.features_title }}</p>
                                                        </li>
                                                    {% endfor %}
