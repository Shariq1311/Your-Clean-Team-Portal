<!--FAQ Two Start-->
<section class="faq-two">
    <div class="faq-two__shape-1">
        <img src="{{ upload_url(data.shape_1|default('images/shapes/faq-two-shape-1.png')) }}" alt="">
    </div>
    <div class="faq-two__shape-2">
        <img src="{{ upload_url(data.shape_2|default('images/shapes/faq-two-shape-2.png')) }}" alt="">
    </div>
    <div class="container">
        <div class="row">
            <div class="col-xl-5">
                <div class="faq-two__left">
                    <div class="section-title text-left sec-title-animation animation-style2">
                        <div class="section-title__tagline-box">
                            <div class="section-title__tagline-shape-1"></div>
                            <span class="section-title__tagline">{{ data.section_tagline|default('FAQS') }}</span>
                            <div class="section-title__tagline-shape-2"></div>
                        </div>
                        <h2 class="section-title__title title-animation">{{ data.section_title|default('Frequently Asked') }}
                            <span>{{ data.section_title_span|default('Questions') }}</span>
                        </h2>
                    </div>
                    <p class="faq-two__text">{{ data.section_description|default('Get answers to the most common questions about our products, services, and policies.') }}</p>
                    <div class="faq-two__bdr"></div>
                    <div class="faq-two__contact">
                        <div class="icon">
                            <span class="icon-customer-service-headset"></span>
                        </div>
                        <div class="content">
                            <span>{{ data.support_label|default('Get Support') }}</span>
                            <p><a href="tel:{{ data.support_phone|default('99 (00) 567 780')|replace({' ': ''}) }}">{{ data.support_phone|default('99 (00) 567 780') }}</a></p>
                        </div>
                    </div>
                    <div class="faq-two__btn-box">
                        <a href="{{ data.button_url|default('#') }}" class="thm-btn">{{ data.button_text|default('Get in Touch') }}<span class="icon-right-arrow"></span></a>
                    </div>
                </div>
            </div>
            <div class="col-xl-7">
                <div class="faq-two__right">
                    <div class="accrodion-grp faq-one-accrodion" data-grp-name="faq-one-accrodion">
                        {% if data.faq_items %}
                            {% for item in data.faq_items %}
                                <div class="accrodion{% if item.is_active %} active{% endif %}">
                                    <div class="accrodion-title">
                                        <h4>{{ item.question }}</h4>
                                    </div>
                                    <div class="accrodion-content">
                                        <div class="inner">
                                            <p class="accrodion-content__text-1">{{ item.answer_part1 }}</p>
                                            <p class="accrodion-content__text-2">{{ item.answer_part2 }}</p>
                                        </div><!-- /.inner -->
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--FAQ Two End--> 

<script>
    (function($) {
        "use strict";
        $(document).ready(function() {
              if ($(".faq-one-accrodion").length) {
                    var accrodionGrp = $(".accrodion-grp");
                    accrodionGrp.each(function () {
                    var accrodionName = $(this).data("grp-name");
                    var Self = $(this);
                    var accordion = Self.find(".accrodion");
                    Self.addClass(accrodionName);
                    Self.find(".accrodion .accrodion-content").hide();
                    Self.find(".accrodion.active").find(".accrodion-content").show();
                    accordion.each(function () {
                        $(this)
                        .find(".accrodion-title")
                        .on("click", function () {
                            if ($(this).parent().hasClass("active") === false) {
                            $(".accrodion-grp." + accrodionName)
                                .find(".accrodion")
                                .removeClass("active");
                            $(".accrodion-grp." + accrodionName)
                                .find(".accrodion")
                                .find(".accrodion-content")
                                .slideUp();
                            $(this).parent().addClass("active");
                            $(this).parent().find(".accrodion-content").slideDown();
                            }
                        });
                    });
                    });
                }
        });
    })(jQuery);
</script>