<!--Services Two Section Start-->
<section class="services-two pt_{{ data.padding_top|default(120) }} xs_pt_{{ data.mobile_padding_top|default(80) }} pb_{{ data.padding_bottom|default(120) }} xs_pb_{{ data.mobile_padding_bottom|default(80) }}">
    <div class="services-two__shape-1"></div>
    <div class="container">
        <div class="services-two__top">
            <div class="section-title text-left sec-title-animation animation-style2 {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s"{% endif %}>
                <div class="section-title__tagline-box">
                    <div class="section-title__tagline-shape-1"></div>
                    <span class="section-title__tagline">{{ data.section_tagline|default('Our Services') }}</span>
                    <div class="section-title__tagline-shape-2"></div>
                </div>
                <h2 class="section-title__title title-animation">{{ data.section_title_1|default('Your Business with Cutting-Edge IT') }}<br>
                {{ data.section_title_2|default('Solutions') }} {% if data.section_title_image %}<img src="{{ upload_url(data.section_title_image) }}" alt="">{% endif %}
                <span>{{ data.section_title_3|default('Innovative IT Services') }}</span><br><span>{{ data.section_title_4|default('Tailored for Your Success') }}</span>
                </h2>
            </div>
            <div class="services-two__round-text-box {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s" data-wow-delay="0.3s"{% endif %}>
                <div class="services-two__round-text-box-inner">
                    <div class="services-two__curved-circle">
                        {{ data.round_text|default('View All Project View All Services') }}
                    </div>
                    <div class="services-two__round-icon">
                        {% if data.round_icon %}
                            <img src="{{ upload_url(data.round_icon) }}" alt="">
                        {% else %}
                            <img src="assets/images/icon/services-two-round-icon.png" alt="">
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="services-two__bottom">
            <div class="services-two__services-list">
                {% if data.use_services_post_type %}
                    {% set services = get_posts('services', {
                        'limit': data.items_limit|default(6),
                        'taxonomy': data.services_category,
                        'ids': ids_array
                    }) %}
                    
                    {% if services %}
                        {% for service in services %}
                            <div class="services-two__services-list-single {% if loop.first %}services-two__services-list-single-1{% endif %} {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s" data-wow-delay="{{ loop.index0 * 0.2 }}s"{% endif %}>
                                <div class="services-two__count-and-title">
                                    <div class="services-two__count"></div>
                                    <h3 class="services-two__title"><a href="{{ service.url }}">{{ service.title }}</a></h3>
                                </div>
                                <div class="services-two__service-list-box">
                                    <ul class="services-two__services-list-inner list-unstyled">
                                        {% for feature in service.metas.features_list %}
                                            <li>
                                                <p><span class="icon-plus"></span>{{ feature.features_title_1 }}</p>
                                                <p><span class="icon-plus"></span>{{ feature.features_title_2 }}</p>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                                <div class="services-two__hover-img">
                                    {% if service.metas.hover_image %}
                                        <img src="{{ upload_url(service.metas.hover_image) }}" alt="{{ service.title }}">
                                    {% elseif service.thumbnail %}
                                        <img src="{{ upload_url(service.thumbnail) }}" alt="{{ service.title }}">
                                    {% else %}
                                        <img src="assets/images/services/services-2-1.jpg" alt="{{ service.title }}">
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                {% else %}
                    {% if data.custom_services %}
                        {% for service in data.custom_services %}
                            <div class="services-two__services-list-single {% if loop.first %}services-two__services-list-single-1{% endif %} {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s" data-wow-delay="{{ loop.index0 * 0.2 }}s"{% endif %}>
                                <div class="services-two__count-and-title">
                                    <div class="services-two__count"></div>
                                    <h3 class="services-two__title"><a href="{{ service.url|default('#') }}">{{ service.title }}</a></h3>
                                </div>
                                <div class="services-two__service-list-box">
                                    <ul class="services-two__services-list-inner list-unstyled">
                                        {% if service.features %}
                                            {% for feature_pair in service.features %}
                                                <li>
                                                    {% if feature_pair.feature_1 %}<p><span class="icon-plus"></span>{{ feature_pair.feature_1 }}</p>{% endif %}
                                                    {% if feature_pair.feature_2 %}<p><span class="icon-plus"></span>{{ feature_pair.feature_2 }}</p>{% endif %}
                                                </li>
                                            {% endfor %}
                                        {% endif %}
                                    </ul>
                                </div>
                                <div class="services-two__hover-img">
                                    {% if service.hover_image %}
                                        <img src="{{ upload_url(service.hover_image) }}" alt="{{ service.title }}">
                                    {% else %}
                                        <img src="assets/images/services/services-2-{{ loop.index }}.jpg" alt="{{ service.title }}">
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <!-- Default Services -->
                        <div class="services-two__services-list-single services-two__services-list-single-1 {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s"{% endif %}>
                            <div class="services-two__count-and-title">
                                <div class="services-two__count"></div>
                                <h3 class="services-two__title"><a href="javascript:void(0)">Software Development<br> Solutions</a></h3>
                            </div>
                            <div class="services-two__service-list-box">
                                <ul class="services-two__services-list-inner list-unstyled">
                                    <li>
                                        <p><span class="icon-plus"></span>UI/UX Design</p>
                                        <p><span class="icon-plus"></span>Mobile Application</p>
                                    </li>
                                    <li>
                                        <p><span class="icon-plus"></span>Mobile Application</p>
                                        <p><span class="icon-plus"></span>Research</p>
                                    </li>
                                    <li>
                                        <p><span class="icon-plus"></span>Research</p>
                                        <p><span class="icon-plus"></span>UI/UX Design</p>
                                    </li>
                                </ul>
                            </div>
                            <div class="services-two__hover-img">
                                <img src="assets/images/services/services-2-1.jpg" alt="Image">
                            </div>
                        </div>
                        <div class="services-two__services-list-single {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s" data-wow-delay="0.2s"{% endif %}>
                            <div class="services-two__count-and-title">
                                <div class="services-two__count"></div>
                                <h3 class="services-two__title"><a href="javascript:void(0)">Cybersecurity Risk<br> Management</a></h3>
                            </div>
                            <div class="services-two__service-list-box">
                                <ul class="services-two__services-list-inner list-unstyled">
                                    <li>
                                        <p><span class="icon-plus"></span>Security</p>
                                        <p><span class="icon-plus"></span>Performance</p>
                                    </li>
                                    <li>
                                        <p><span class="icon-plus"></span>Scalability</p>
                                        <p><span class="icon-plus"></span>Reliability</p>
                                    </li>
                                    <li>
                                        <p><span class="icon-plus"></span>Innovation</p>
                                        <p><span class="icon-plus"></span>Efficiency</p>
                                    </li>
                                </ul>
                            </div>
                            <div class="services-two__hover-img">
                                <img src="assets/images/services/services-2-2.jpg" alt="Image">
                            </div>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</section>
<!--Services Two Section End-->