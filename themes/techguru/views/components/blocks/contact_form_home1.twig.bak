<section class="contact-two">
    <ul class="contact-two__sliding-text-list list-unstyled {{ data.marquee_class|default('marquee_mode-2') }}">
        {% if data.sliding_text_items %}
            {% for item in data.sliding_text_items %}
                <li>
                    <h2 data-hover="{{ item.hover_text }}" class="contact-two__sliding-text-title">{{ item.text }}</h2>
                </li>
            {% endfor %}
        {% else %}
            <li>
                <h2 data-hover="Branding" class="contact-two__sliding-text-title">GET IN TOUCH *</h2>
            </li>
            <li>
                <h2 data-hover="Branding" class="contact-two__sliding-text-title">GET IN TOUCH *</h2>
            </li>
            <li>
                <h2 data-hover="Branding" class="contact-two__sliding-text-title">GET IN TOUCH *</h2>
            </li>
        {% endif %}
    </ul>
    <div class="contact-two__bg" style="background-image: url({% if data.bg_image %}{{ upload_url(data.bg_image) }}{% else %}{{ asset('images/backgrounds/contact-two-bg.jpg') }}{% endif %});">
    </div>
    <div class="contact-two__shape-1 float-bob-y">
        <img src="{% if data.shape_1 %}{{ upload_url(data.shape_1) }}{% else %}{{ asset('images/shapes/contact-two-shape-1.png') }}{% endif %}" alt="">
    </div>
    <div class="contact-two__shape-2"></div>
    <div class="container">
        <div class="row">
            <div class="col-xl-6">
                <div class="contact-two__left">
                    <div class="section-title text-left sec-title-animation animation-style2">
                        <div class="section-title__tagline-box">
                            <div class="section-title__tagline-shape-1"></div>
                            <span class="section-title__tagline">{{ data.section_tagline|default('Get In Touch') }}</span>
                            <div class="section-title__tagline-shape-2"></div>
                        </div>
                        <h2 class="section-title__title title-animation">{{ data.title_part_1|default('Conversation') }}
                            <span>{{ data.title_part_2|default('– Reach') }}</span><br><span>{{ data.title_part_3|default('Out Anytime') }}</span>
                        </h2>
                    </div>
                    <p class="contact-two__text">{{ techguru_format_text(data.description|default('We\'re here to listen! Whether you have \\ questions, feedback, or just want to say hello, \\ feel free to reach out.')) }}</p>  
                    <ul class="contact-two__contact-list list-unstyled">
                        <li>
                            <div class="icon">
                                <span class="icon-mail"></span>
                            </div>
                            <div class="content">
                                <span>{{ data.email_title|default('Email Us') }}</span>
                                <p><a href="mailto:{{ data.email_address|default('info@domain.com') }}">{{ data.email_address|default('info@domain.com') }}</a></p>
                            </div>
                        </li>
                        <li>
                            <div class="icon">
                                <span class="icon-phone-call"></span>
                            </div>
                            <div class="content">
                                <span>{{ data.contact_title|default('Contact US') }}</span>
                                <p><a href="tel:{{ data.phone_number|default('+99 (00) 567 780')|replace({' ': ''}) }}">{{ data.phone_number|default('+99 (00) 567 780') }}</a></p>
                            </div>
                        </li>
                        <li>
                            <div class="icon">
                                <span class="icon-pin"></span>
                            </div>
                            <div class="content">
                                <span>{{ data.address_title|default('Our Address') }}</span>
                                <p>{{ data.address|default('1629 N. Dixie Avenue, Kentucky, 42701') }}</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="contact-two__right {% if data.enable_animation %}wow slideInRight{% endif %}" {% if data.enable_animation %}data-wow-delay="100ms" data-wow-duration="2500ms"{% endif %}>
                    <div id="contact-success-message" class="alert alert-success" style="display: none;"></div>
                    <div id="contact-error-message" class="alert alert-danger" style="display: none;"></div>
                    <form class="contact-form-validated contact-one__form" id="contactFormHome1" action="{{ url('ajax/contact') }}" method="POST" novalidate="novalidate">
                        <div class="row">
                            <div class="col-xl-6 col-lg-6">
                                <h4 class="contact-one__input-title">{{ data.form_name_label|default('Full Name') }}</h4>
                                <div class="contact-one__input-box">
                                    <div class="contact-one__input-icon">
                                        <span class="icon-user-1"></span>
                                    </div>
                                    <input type="text" name="name" placeholder="{{ data.form_name_placeholder|default('Thomas Alison') }}" required="">
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6">
                                <h4 class="contact-one__input-title">{{ data.form_email_label|default('Email Address') }}</h4>
                                <div class="contact-one__input-box">
                                    <div class="contact-one__input-icon">
                                        <span class="icon-email"></span>
                                    </div>
                                    <input type="email" name="email" placeholder="{{ data.form_email_placeholder|default('thomas@domain.com') }}" required="">
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6">
                                <h4 class="contact-one__input-title">{{ data.form_phone_label|default('Phone Number') }}</h4>
                                <div class="contact-one__input-box">
                                    <div class="contact-one__input-icon">
                                        <span class="icon-phone-call"></span>
                                    </div>
                                    <input type="text" name="phone" placeholder="{{ data.form_phone_placeholder|default('+12 (00) 123 4567 890') }}" required="">
                                </div>
                            </div>
                            <div class="col-xl-6 col-lg-6">
                                <h4 class="contact-one__input-title">{{ data.form_subject_label|default('Subject') }}</h4>
                                <div class="contact-one__input-box">
                                    <div class="select-box">
                                        <select class="selectmenu wide" name="subject">
                                            {% if data.subject_options %}
                                                {% for option in data.subject_options %}
                                                    <option {% if option.selected %}selected="selected"{% endif %}>{{ option.text }}</option>
                                                {% endfor %}
                                            {% else %}
                                                <option selected="selected">Thomas Alison</option>
                                                <option>Type Of Service 01</option>
                                                <option>Type Of Service 02</option>
                                                <option>Type Of Service 03</option>
                                                <option>Type Of Service 04</option>
                                                <option>Type Of Service 05</option>
                                            {% endif %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-xl-12">
                            <h4 class="contact-one__input-title">{{ data.form_message_label|default('Inquiry about') }} </h4>
                            <div class="contact-one__input-box text-message-box">
                                <div class="contact-one__input-icon">
                                    <span class="icon-edit"></span>
                                </div>
                                <textarea name="message" placeholder="{{ data.form_message_placeholder|default('Write your message') }}"></textarea>
                            </div>
                            <div class="contact-one__btn-box">
                                <button type="submit" class="thm-btn"><span>{{ data.submit_button_text|default('Submit Now') }}</span><i class="icon-right-arrow"></i></button>
                            </div>
                        </div>
                    </form>
                    <div class="result"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function($) {
        "use strict";
        $(document).ready(function() {
            $('select:not(.ignore)').niceSelect();
            // Initialize marquee
            if ($(".{{ data.marquee_class|default('marquee_mode-2') }}").length) {
                $('.{{ data.marquee_class|default('marquee_mode-2') }}').marquee({
                    speed: {{ data.scroll_speed|default(30) }},
                    gap: 0,
                    delayBeforeStart: 0,
                    direction: 'left',
                    duplicated: true,
                    pauseOnHover: {{ data.pause_on_hover ? 'true' : 'false' }},
                    startVisible: true,
                });
            }
            
            // Form submission
            $('#contactFormHome1').on('submit', function(e) {
                e.preventDefault();
                $.ajaxSetup({
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    }
                });

                $.ajax({
                    url: '{{ url('ajax/contact') }}',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function(response) {
                        if (response.status === true) {
                            $('#contact-success-message').show();
                            $('#contact-success-message').text(response?.data?.message || 'Your message has been sent successfully!');
                            $('#contactFormHome1')[0].reset();
                        } else {
                            $('#contact-error-message').show();
                            $('#contact-error-message').text(response?.data?.message || 'Something went wrong!');
                        }
                    },
                    error: function(xhr, status, error) {
                        $('#contact-error-message').show();
                        $('#contact-error-message').text(xhr.responseJSON?.message || 'An error occurred. Please try again.');
                    }
                });
            });
        });
    })(jQuery);
</script> 