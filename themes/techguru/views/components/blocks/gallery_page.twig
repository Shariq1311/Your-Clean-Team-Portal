<!--Gallery Page Section Start-->
<section class="gallery-page pt_{{ data.padding_top|default(120) }} xs_pt_{{ data.mobile_padding_top|default(80) }} pb_{{ data.padding_bottom|default(120) }} xs_pb_{{ data.mobile_padding_bottom|default(80) }}">
    <div class="container">
        <div class="row {% if data.enable_masonry %}masonary-layout{% endif %}">
            {% if data.gallery_items %}
                {% for item in data.gallery_items %}
                    <!--Gallery Page Single Start-->
                    <div class="{{ item.column_size|default('col-xl-3 col-lg-6 col-md-6') }} {% if data.enable_animation %}wow {{ data.animation_type|default('fadeInUp') }}{% endif %}" {% if data.enable_animation %}data-wow-duration="1s" data-wow-delay="{{ loop.index0 * 0.1 }}s"{% endif %}>
                        <div class="gallery-page__single">
                            <div class="gallery-page__img">
                                <div class="gallery-page__img-box">
                                    <img src="{{ upload_url(item.image) }}" alt="{{ item.alt_text|default('Gallery image') }}">
                                </div>
                                {% if data.enable_lightbox %}
                                    <div class="gallery-page__icon">
                                        {% set lightbox_url = item.lightbox_image ? upload_url(item.lightbox_image) : upload_url(item.image) %}
                                        <a class="img-popup" href="{{ lightbox_url }}"><span class="icon-plus"></span></a>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <!--Gallery Page Single End-->
                {% endfor %}
