
    <div class="custom-cursor__cursor"></div>
    <div class="custom-cursor__cursor-two"></div>

<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 10000;"></div>

    <!--Start Preloader-->
    <div class="loader js-preloader">
        <div></div>
        <div></div>
        <div></div>
    </div>
    <!--End Preloader-->

    <!-- Start sidebar widget content -->
    <div class="xs-sidebar-group info-group info-sidebar">
        <div class="xs-overlay xs-bg-black"></div>
        <div class="xs-sidebar-widget">
            <div class="sidebar-widget-container">
                <div class="widget-heading">
                    <a href="#" class="close-side-widget">X</a>
                </div>
                <div class="sidebar-textwidget">
                    <div class="sidebar-info-contents">
                        <div class="content-inner">
                            <div class="logo">
                                <a href="{{ url('/') }}"><img src="{{ get_logo() }}" alt="" /></a>    
                            </div>
                            <div class="content-box">   
                                <h4>{{ theme_config('offcanvas_about_us_title')|default('About Us') }}</h4>
                                <p>{{ theme_config('offcanvas_about_us_description')|default('Lorem ipsum dolor sit amet, consectetur elit, sed do eiusmod tempor incididunt ut labore et magna aliqua. Ut enim ad minim veniam laboris.') }}</p>
                            </div>
                            <div class="form-inner">
                                <h4>{{ theme_config('offcanvas_get_a_free_quote_title')|default('Get a free quote') }}</h4>
                                <div id="contact-success-message-header" class="alert alert-success" style="display: none;"></div>
                                <div id="contact-error-message-header" class="alert alert-danger" style="display: none;"></div>
                                    <form class="contact-form-validated contact-one__form" id="contactFormHeader" action="{{ url('ajax/contact') }}" method="POST" novalidate="novalidate">
                                    <div class="form-group">
                                        <input type="text" name="name" placeholder="Name" required="">
                                    </div>
                                    <div class="form-group">
                                        <input type="email" name="email" placeholder="Email" required="">
                                    </div>
                                    <div class="form-group">
                                        <input type="text" name="subject" placeholder="Subject" required="">
                                    </div>
                                    <div class="form-group">
                                        <textarea name="message" placeholder="Message..."></textarea>
                                    </div>
                                    <div class="form-group message-btn">
                                        <button type="submit" class="thm-btn form-inner__btn">
                                            {{ theme_config('offcanvas_submit_button_text')|default('Submit Now') }}
                                            <span class="icon-right-arrow"></span>
                                        </button>
                                    </div>
                                </form>
                                <div class="result"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- End sidebar widget content -->

    <div class="page-wrapper">

    {% set header_style = post.metas.header_style|default('header-1') %}
        {% if header_style == 'header-2' %}
            <header class="main-header">
                <div class="main-menu__top">
                    <div class="container">
                        <div class="main-menu__top-inner">
                            <div class="main-menu__top-social">
                                {% if theme_config('facebook_url') %}
                                    <a href="{{ theme_config('facebook_url') }}" target="_blank"><span class="icon-facebook"></span></a>
                                {% endif %}
                                {% if theme_config('dribble_url') %}
                                    <a href="{{ theme_config('dribble_url') }}" target="_blank"><span class="icon-dribble"></span></a>
                                {% endif %}
                                {% if theme_config('linkedin_url') %}
                                    <a href="{{ theme_config('linkedin_url') }}"><span class="icon-linkedin"></span></a>
                                {% endif %}
                                {% if theme_config('twitter_url') %}
                                    <a href="{{ theme_config('twitter_url') }}" target="_blank"><span class="icon-twitter"></span></a>
                                {% endif %}
                                {% if theme_config('instagram_url') %}
                                    <a href="{{ theme_config('instagram_url') }}" target="_blank"><span class="icon-instagram"></span></a>
                                {% endif %}
                                {% if theme_config('youtube_url') %}
                                    <a href="{{ theme_config('youtube_url') }}" target="_blank"><span class="icon-youtube"></span></a>
                                {% endif %}
                                {% if theme_config('pinterest_url') %}
                                    <a href="{{ theme_config('pinterest_url') }}" target="_blank"><span class="icon-pinterest"></span></a>
                                {% endif %}
                            </div>
                            <ul class="list-unstyled main-menu__contact-list">
                                <li>
                                    <div class="icon">
                                        <i class="icon-pin"></i>
                                    </div>
                                    <div class="text">
                                        <p>{{ theme_config('address')|default('1629 N. Dixie Avenue, Kentucky, 42701') }}</p>
                                    </div>
                                </li>
                                <li>
                                    <div class="icon">
                                        <i class="icon-search-mail"></i>
                                    </div>
                                    <div class="text">
                                        <p><a href="mailto:{{ theme_config('email')|default('example@domain.com') }}">{{ theme_config('email')|default('example@domain.com') }}</a>
                                        </p>
                                    </div>
                                </li>
                                <li>
                                    <div class="icon">
                                        <i class="icon-phone-call"></i>
                                    </div>
                                    <div class="text">
                                        <p><a href="tel:{{ theme_config('phone')|default('1212345678900') }}">{{ theme_config('phone')|default('+12 (123) 456 78900') }}</a></p>
                                    </div>
                                </li>
                            </ul>
                            {{  mc_nav_menu({
                                'container_before': '<ul class="list-unstyled main-menu__top-menu">',
                                'container_after': '</ul>',
                                'theme_location': 'top_bar_menu',         
                                'item_view': 'theme::components.menu_item'
                            }) }}
                        </div>
                    </div>
                </div>
                <nav class="main-menu">
                    <div class="main-menu__wrapper">
                        <div class="container">
                            <div class="main-menu__wrapper-inner">
                                <div class="main-menu__left">
                                    <div class="main-menu__logo">
                                        <a href="{{ url('/') }}"><img src="{{ get_logo() }}" alt=""></a>
                                    </div>
                                </div>
                                <div class="main-menu__main-menu-box">
                                    <a href="javascript:void(0)" class="mobile-nav__toggler"><i class="fa fa-bars"></i></a>
                                    {{  mc_nav_menu({
                                        'container_before': '<ul class="main-menu__list">',
                                        'container_after': '</ul>',
                                        'theme_location': 'primary',
                                        'item_view': 'theme::components.menu_item'
                                    }) }}
                                </div>
                                <div class="main-menu__right">
                                    <div class="main-menu__search-box">
                                        <a href="javascript:void(0)"
                                            class="main-menu__search searcher-toggler-box icon-search-interface-symbol"></a>
                                    </div>
                                    <div class="main-menu__btn-box">
                                        <a href="{{ theme_config('contact_button_url')|default('#') }}" class="thm-btn">
                                            {{ theme_config('contact_button_text')|default('Get in Touch') }}
                                            <span class="icon-right-arrow"></span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>
            </header>
        {% else %}
            <header class="main-header-two">
                <div class="main-menu-two__top">
                    <div class="main-menu-two__top-inner">
                        <p class="main-menu-two__top-text">
                            {{ theme_config('top_bar_text')|default('techguru That Ensures Your IT Runs Seamlessly, Anytime and Every Time') }}
                        </p>
                        <ul class="list-unstyled main-menu-two__contact-list">
                            <li>
                                <div class="icon">
                                    <i class="icon-pin"></i>
                                </div>
                                <div class="text">
                                    <p>{{ theme_config('address')|default('1629 N. Dixie Avenue, Kentucky, 42701') }}</p>
                                </div>
                            </li>
                            <li>
                                <div class="icon">
                                    <i class="icon-search-mail"></i>
                                </div>
                                <div class="text">
                                    <p><a href="mailto:{{ theme_config('email')|default('example@domain.com') }}">{{ theme_config('email')|default('example@domain.com') }}</a>
                                    </p>
                                </div>
                            </li>
                            <li>
                                <div class="icon">
                                    <i class="icon-phone-call"></i>
                                </div>
                                <div class="text">
                                    <p><a href="tel:{{ theme_config('phone')|default('1212345678900') }}">{{ theme_config('phone')|default('+12 (123) 456 78900') }}</a></p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
                <nav class="main-menu main-menu-two">
                    <div class="main-menu-two__wrapper">
                        <div class="main-menu-two__wrapper-inner">
                            <div class="main-menu-two__left">
                                <div class="main-menu-two__logo">
                                    <a href="{{ url('/') }}"><img src="{{ get_logo() }}" alt=""></a>  
                                </div>
                            </div>
                            <div class="main-menu-two__main-menu-box">
                                <a href="javascript:void(0)" class="mobile-nav__toggler"><i class="fa fa-bars"></i></a>
                                {{  mc_nav_menu({
                                    'container_before': '<ul class="main-menu__list">',
                                    'container_after': '</ul>',
                                    'theme_location': 'primary',
                                    'item_view': 'theme::components.menu_item'
                                }) }}
                            </div>
                            <div class="main-menu-two__right">
                                                            <div class="main-menu-two__search-box">
                                <a href="{{ url('/wishlist') }}"
                                    class="main-menu-two__search wishlist-toggler-box">
                                    <i class="fal fa-heart"></i>
                                    <span class="wishlist-count">{{ ecom_get_wishlist().total_items ?? 0 }}</span>
                                </a>
                            </div>
                            <div class="main-menu-two__search-box">
                                <a href="{{ url('/cart') }}"
                                    class="main-menu-two__search cart-toggler-box">
                                    <i class="fal fa-shopping-cart"></i>
                                    <span class="cart-count">{{ cart.totalItems() ?? 0 }}</span>
                                </a>
                            </div>
                                <div class="main-menu-two__search-box">
                                    <a href="javascript:void(0)"
                                        class="main-menu-two__search searcher-toggler-box icon-search-interface-symbol"></a>
                                </div>
                                <div class="main-menu-two__btn-box">
                                    <a href="{{ theme_config('contact_button_url')|default('#') }}" class="thm-btn">
                                        {{ theme_config('contact_button_text')|default('Get in Touch') }}
                                        <span class="icon-right-arrow"></span>
                                    </a>
                                </div>
                                <div class="main-menu-two__nav-sidebar-icon">
                                    <a class="navSidebar-button" href="javascript:void(0)">
                                        <span class="icon-dots-menu-one"></span>
                                        <span class="icon-dots-menu-two"></span>
                                        <span class="icon-dots-menu-three"></span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </nav>
            </header>
        {% endif %}

        <div class="stricky-header stricked-menu main-menu main-menu-two">
            <div class="sticky-header__content"></div><!-- /.sticky-header__content -->
        </div><!-- /.stricky-header -->


        <script>
            (function($) {
                "use strict";
                $(document).ready(function() {
                    $('#contactFormHeader').on('submit', function(e) {
                        e.preventDefault();
                        $.ajaxSetup({
                            headers: {
                                'X-CSRF-TOKEN': '{{ csrf_token() }}'
                            }
                        });

                        $.ajax({
                            url: '{{ url('ajax/contact') }}',
                            type: 'POST',
                            data: $(this).serialize(),
                            success: function(response) {
                                if (response.status === true) {
                                    $('#contact-success-message-header').show();
                                    $('#contact-success-message-header').text(response?.data?.message || 'Your message has been sent successfully!');
                                    $('#contactFormHeader')[0].reset();
                                } else {
                                    $('#contact-error-message-header').show();
                                    $('#contact-error-message-header').text(response?.data?.message || 'Something went wrong!');
                                }
                            },
                            error: function(xhr, status, error) {
                                $('#contact-error-message-header').show();
                                $('#contact-error-message-header').text(xhr.responseJSON?.message || 'An error occurred. Please try again.');
                            }
                        });
                    });
                });
            })(jQuery);
        </script>