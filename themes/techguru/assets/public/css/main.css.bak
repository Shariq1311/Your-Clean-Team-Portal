}

.testimonial-one__bg {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 26.2%;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    border-top-right-radius: 40px;
    border-bottom-right-radius: 40px;
