}


/*--------------------------------------------------------------
# End
--------------------------------------------------------------*/

.portfolio-details__points-two-single .icon p.icon-tick-inside-circle {
    position: relative;
    display: inline-block;
    font-size: 16px;
    color: var(--techguru-base);
}

.portfolio-details__portfolio-list-three-single .icon p.icon-tick-inside-circle {
