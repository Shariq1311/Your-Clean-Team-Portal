}

.offcanvas-backdrop::before {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1039;
    width: 100vw;
    height: 100vh;
    content: "";
    background-color: rgba(0, 0, 0, .5)
}

.clearfix::after {
    display: block;
    clear: both;
    content: ""
}

