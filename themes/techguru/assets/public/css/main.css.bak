}

.comment-one__btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(270deg, #6065D4 0%, #FA5674 100%);
    opacity: 0;
