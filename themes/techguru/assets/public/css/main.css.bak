    padding: 140px 0 0px;
    overflow: hidden;
    z-index: 1;
}

.testimonial-one::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: rgba(var(--techguru-white-rgb), .05);
