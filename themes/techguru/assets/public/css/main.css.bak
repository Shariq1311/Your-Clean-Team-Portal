    border-radius: 50%;
    overflow: hidden;
    transform: rotate(-90deg);
}

.blog-two__user-img img {
    width: 100%;
    border-radius: 50%;
}

.blog-two__user-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--techguru-white);
}

.blog-two__meta {
    position: relative;
    display: flex;
    align-items: center;
    margin-bottom: 15px;
}

.blog-two__meta li {
    position: relative;
    display: block;
}

.blog-two__meta li+li {
    margin-left: 26px;
}

.blog-two__meta li::before {
    content: "";
    position: absolute;
    top: 3px;
    bottom: 3px;
    left: -13px;
    border: 1px solid transparent;
    background: linear-gradient(180deg, #3D72FC, #5CB0E9) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box,
        linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    -webkit-transition: all 500ms ease;
    -moz-transition: all 500ms ease;
    -ms-transition: all 500ms ease;
    -o-transition: all 500ms ease;
    transition: all 500ms ease;
    visibility: visible;
    opacity: 1;
}

.blog-two__meta li:first-child::before {
    display: none;
}

.blog-two__meta li a {
    position: relative;
    display: flex;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    line-height: 20px;
    color: var(--techguru-gray);
    -webkit-transition: all 500ms ease;
    transition: all 500ms ease;
}

.blog-two__meta li a:hover {
    color: var(--techguru-base);
}

.blog-two__meta li a span {
    position: relative;
    font-size: 14px;
    margin-right: 6px;
    color: var(--techguru-base);
}

.blog-two__title {
    font-size: 24px;
    font-weight: 700;
    line-height: 34px;
    margin-bottom: 18px;
}

.blog-two__title a {
    color: var(--techguru-white);
}

.blog-two__title a:hover {
    color: var(--techguru-base);
}

.blog-two__text {
    font-size: 16px;
    margin-bottom: 17px;
}

.blog-two__btn-box {
    position: relative;
    display: block;
}

.blog-two__btn-box .thm-btn {
    padding: 13px 25px 13px;
    border-radius: 22px;
}

.blog-two__right {
    position: relative;
    display: block;
}

.blog-two__single-two {
    position: relative;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    background: linear-gradient(270deg, rgba(36, 46, 75, 0.4) 0%, rgba(29, 37, 63, 0.4) 100%);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 14px 14px 14px;
    margin-bottom: 40px;
}

.blog-two__img-two {
    position: relative;
    display: block;
    border-radius: 28px;
    overflow: hidden;
    max-width: 250px;
    z-index: 1;
}

.blog-two__img-two:before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: rgba(var(--techguru-black-rgb), 1);
    opacity: 0;
    transition: background-color 0.5s ease;
    transition: all 0.5s ease;
    z-index: 1;
}

.blog-two__single-two:hover .blog-two__img-two:before {
    opacity: .50;
}

.blog-two__img-two img {
    width: 100%;
    border-radius: 28px;
    transform: scale3d(1, 1, 1);
    transition: transform 1s ease-in-out;
}

.blog-two__single-two:hover .blog-two__img-two img {
    transform: scale(1.05) rotate(0deg);
}

.blog-two__content-two {
    position: relative;
    display: block;
    flex: 1;
    padding-left: 75px;
}

.blog-two__user-two {
    position: absolute;
    top: 76px;
    left: -37px;
