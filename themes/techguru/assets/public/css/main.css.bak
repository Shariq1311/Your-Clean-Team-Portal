    align-items: center;
    gap: 9px;
    padding: 3px 12px 3px;
    border-radius: 15px;
    color: var(--techguru-white);
    overflow: hidden;
    background: linear-gradient(270deg, #5CB0E9 0%, #3D72FC 100%);
