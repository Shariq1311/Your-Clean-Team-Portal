{
    "label": "Gallery Page",
    "description": "Display gallery images in a masonry layout with lightbox popup functionality",
    "form": [
        {
            "type": "repeater",
            "name": "gallery_items",
            "label": "Gallery Images",
            "fields": [
                {
                    "type": "image",
                    "name": "image",
                    "label": "Gallery Image"
                },
                {
                    "type": "text",
                    "name": "alt_text",
                    "label": "Alt Text",
                    "description": "Alternative text for the image"
                },
                {
                    "type": "select",
                    "name": "column_size",
                    "label": "Column Size",
                    "description": "Choose the column width for this image",
                    "data": {
                        "options": {
                            "col-xl-3 col-lg-6 col-md-6": "1/4 Width (3 columns)",
                            "col-xl-6 col-lg-6 col-md-6": "1/2 Width (6 columns)",
                            "col-xl-4 col-lg-6 col-md-6": "1/3 Width (4 columns)",
                            "col-xl-8 col-lg-12 col-md-12": "2/3 Width (8 columns)",
                            "col-xl-9 col-lg-12 col-md-12": "3/4 Width (9 columns)",
                            "col-xl-12 col-lg-12 col-md-12": "Full Width (12 columns)"
                        },
                        "value": "col-xl-3 col-lg-6 col-md-6"
                    }
                },
                {
                    "type": "text",
                    "name": "lightbox_image",
                    "label": "Lightbox Image URL",
                    "description": "Optional: Different image URL for lightbox popup (if empty, uses main image)"
                }
            ],
            "options": {
                "min_items": 1,
                "max_items": 20,
                "add_button_text": "Add Gallery Image",
                "remove_button_text": "Remove Image",
                "value": [
                    {
                        "image": "images/gallery/gallery-page-1-1.jpg",
