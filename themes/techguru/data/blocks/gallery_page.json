        {
            "type": "checkbox_json",
            "name": "enable_lightbox",
            "label": "Enable Lightbox",
            "description": "Enable lightbox popup functionality for images",
            "data": {
                "value": 1
            }
        },
        {
            "type": "checkbox_json",
            "name": "enable_masonry",
            "label": "Enable Masonry Layout",
            "description": "Enable masonry layout for better image arrangement",
            "data": {
                "value": 1
            }
        },
        {
            "type": "checkbox_json",
            "name": "enable_animation",
            "label": "Enable Animation",
            "description": "Enable wow animation effects for gallery items",
            "data": {
                "value": 1
            }
        },
        {
            "type": "select",
            "name": "animation_type",
            "label": "Animation Type",
            "data": {
                "options": {
                    "fadeInUp": "Fade In Up",
                    "fadeIn": "Fade In",
                    "zoomIn": "Zoom In",
                    "fadeInLeft": "Fade In Left",
                    "fadeInRight": "Fade In Right"
                },
