{
    "label": "FAQ Page",
    "description": "Display FAQ section with accordion layout and optional CTA section below",
    "form": [
        {
            "type": "text",
            "name": "section_tagline",
            "label": "Section Tagline",
            "data": {
                "value": "FAQS"
            }
        },
        {
            "type": "textarea",
            "name": "section_title",
            "label": "Section Title",
            "data": {
                "value": "Get answers to the most common<br> questions about our products, services,<br> and policies."
            }
        },
        {
            "type": "checkbox_json",
            "name": "use_faqs_post_type",
            "label": "Use FAQs Post Type",
            "description": "Load FAQs from FAQs post type instead of manual configuration",
            "data": {
                "value": 1
            }
        },
        {
            "type": "taxonomy",
            "name": "faqs_category",
            "label": "FAQs Category Filter",
            "description": "Filter FAQs by category (when using FAQs post type)",
            "data": {
                "post_type": "faqs",
                "taxonomy": "categories"
            }
        },
        {
            "type": "text",
            "name": "items_limit",
            "label": "Number of FAQs",
            "description": "Maximum number of FAQs to display",
            "data": {
                "value": "10"
            }
        },
        {
            "type": "text",
            "name": "faq_ids",
            "label": "FAQ IDs",
            "description": "Enter specific FAQ IDs to display (comma-separated)",
            "data": {
                "value": ""
            }
        },
        {
            "type": "select",
            "name": "orderby",
            "label": "Order By",
            "data": {
                "options": {
                    "date": "Date",
                    "title": "Title",
                    "menu_order": "Menu Order",
                    "rand": "Random"
                },
                "value": "date"
            }
        },
        {
            "type": "select",
            "name": "order",
            "label": "Order",
            "data": {
                "options": {
                    "DESC": "Descending",
                    "ASC": "Ascending"
                },
                "value": "DESC"
            }
        },
        {
            "type": "repeater",
            "name": "custom_faqs",
            "label": "Custom FAQs (Manual Configuration)",
            "fields": [
                {
                    "type": "text",
                    "name": "question",
                    "label": "FAQ Question"
                },
                {
                    "type": "textarea",
                    "name": "answer_1",
                    "label": "Answer Part 1"
                },
                {
                    "type": "textarea",
                    "name": "answer_2",
                    "label": "Answer Part 2 (Optional)",
                    "description": "Optional second paragraph for the answer"
                },
                {
                    "type": "checkbox_json",
                    "name": "is_active",
                    "label": "Is Active by Default",
                    "description": "Show this FAQ as expanded by default"
                }
            ],
            "options": {
                "min_items": 0,
                "max_items": 15,
                "add_button_text": "Add FAQ",
                "remove_button_text": "Remove FAQ",
                "value": [
                    {
