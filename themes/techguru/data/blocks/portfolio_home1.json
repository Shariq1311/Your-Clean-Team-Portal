        {
            "type": "checkbox_json",
            "name": "use_portfolio_post_type",
            "label": "Use Portfolio Post Type",
            "description": "Load portfolio items from Portfolio post type instead of manual configuration",
            "data": {
                "value": 1
            }
        },
        {
            "type": "taxonomy",
            "name": "portfolio_category",
            "label": "Portfolio Category Filter",
            "description": "Filter portfolio items by category (when using portfolio post type)",
            "data": {
                "post_type": "portfolio",
                "taxonomy": "categories"
            }
        },
        {
            "type": "text",
            "name": "items_limit",
            "label": "Number of Portfolio Items",
