        {
            "type": "checkbox_json",
            "name": "carousel_loop",
            "label": "Carousel Loop",
            "description": "Enable infinite loop for carousel",
            "data": {
                "value": 1
            }
        },
        {
            "type": "text",
            "name": "carousel_margin",
            "label": "Carousel Item Margin",
            "description": "Margin between carousel items in pixels",
            "data": {
                "value": "0"
            }
        },
        {
            "type": "checkbox_json",
            "name": "carousel_nav",
