                            "name": "title",
                            "label": "Portfolio Title"
                        },
                        {
                            "type": "textarea",
                            "name": "description",
                            "label": "Portfolio Description"
                        },
                        {
                            "type": "text",
                            "name": "url",
                            "label": "Portfolio Detail URL"
                        },
                        {
                            "type": "checkbox_json",
                            "name": "is_active",
                            "label": "Is Active Item",
                            "description": "Mark this item as active (highlighted)",
