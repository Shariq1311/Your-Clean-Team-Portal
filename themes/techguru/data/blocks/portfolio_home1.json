        },
        {
            "type": "select",
            "name": "orderby",
            "label": "Order By",
            "data": {
                "options": {
                    "date": "Date",
                    "title": "Title",
                    "menu_order": "Menu Order",
                    "rand": "Random"
                },
                "value": "date"
            }
        },
        {
            "type": "select",
            "name": "order",
            "label": "Order",
            "data": {
                "options": {
                    "DESC": "Descending",
                    "ASC": "Ascending"
                },
                "value": "DESC"
            }
        },
        {
            "type": "repeater",
            "name": "portfolio_groups",
            "label": "Portfolio Groups (Manual Configuration)",
            "description": "Each group represents a carousel item with multiple portfolio items",
