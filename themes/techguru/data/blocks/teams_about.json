                "value": "images/shapes/team-two-bg-shape.png"
            }
        },
        {
            "type": "checkbox_json",
            "name": "use_teams_post_type",
            "label": "Use Teams Post Type",
            "description": "Load team members from Teams post type instead of manual configuration",
            "data": {
                "value": 1
            }
        },
        {
            "type": "taxonomy",
            "name": "teams_category",
            "label": "Teams Category Filter",
            "description": "Filter team posts by category (when using teams post type)",
            "data": {
                "post_type": "teams",
                "taxonomy": "categories"
            }
        },
        {
            "type": "text",
            "name": "items_limit",
